# Railway Payment Agent environment template.
# Add these as Railway service variables. Do not commit real secrets.

# Runtime
DRY_RUN=true
LOG_LEVEL=INFO
LOG_FORMAT=json
DATABASE_PATH=/data/payment_agent.sqlite3
TIMEZONE=America/New_York
PAYMENT_AGENT_HEALTH_PATH=/data/payment_agent_health.json
PAYMENT_AGENT_RUN_STARTUP_SCAN=true

# Email scan settings
EMAIL_PROVIDER=microsoft365
MAILBOX_USER_ID=payments@example.com
SENDER_EMAIL=sender@example.com
SUBJECT_CONTAINS=Online Payment -
SCAN_INTERVAL_MINUTES=15
LOOKBACK_HOURS=48

# Microsoft Graph app registration for Outlook mailbox scanning and cleanup.
# Required application permissions: Mail.Read, Mail.ReadWrite.
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=

# Payment report settings
DAILY_REPORT_TIME=17:00
REPORT_MODE=daily

# Teams posting option A: webhook.
TEAMS_POST_METHOD=webhook
TEAMS_WEBHOOK_URL=

# Teams posting option B: existing Teams group chat via delegated Graph.
# For Railway, this token cache must live on a persistent volume.
TEAMS_GRAPH_TENANT_ID=
TEAMS_GRAPH_CLIENT_ID=
TEAMS_GRAPH_CLIENT_SECRET=
TEAMS_GRAPH_TOKEN_CACHE_PATH=/data/.graph_teams_token_cache.bin
TEAMS_CHAT_ID=

# Optional email snapshot storage.
SAVE_EMAIL_HTML=false
EMAIL_SNAPSHOT_DIR=/data/email_snapshots
