# Copy this file to .env and fill in the values for your environment.
# Do not commit .env to source control.

# Runtime
DRY_RUN=true
LOG_LEVEL=INFO
DATABASE_PATH=payment_agent.sqlite3
TIMEZONE=America/New_York
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080
DASHBOARD_LOGO_PATH=/absolute/path/to/ucm-logo.png
SHARED_DATA_DATABASE_PATH=~/Library/Application Support/UCM/payment-agent/shared_ucm_data.sqlite3
MANAGER_CHECKLIST_URL=
MANAGER_CHECKLIST_SHEET_URL=https://docs.google.com/spreadsheets/d/1jiKKhZmqTnVRiO9Mi8UicB9xda_MNwPQrDsPNaVOWq0/edit

# Email scan settings
EMAIL_PROVIDER=microsoft365
MAILBOX_USER_ID=payments@example.com
SENDER_EMAIL=sender@example.com
SUBJECT_CONTAINS=Online Payment -
SCAN_INTERVAL_MINUTES=15
LOOKBACK_HOURS=48

# Microsoft Graph app registration for reading email.
# Required Graph application permission: Mail.Read
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=

# Daily report settings
DAILY_REPORT_TIME=17:00
REPORT_MODE=daily
# Options: daily, realtime, both

# Teams posting.
# Option A: incoming webhook URL. Simpler for channel posts.
TEAMS_WEBHOOK_URL=

# Option B: Microsoft Graph Teams/chat posting.
# Requires additional Graph permissions and destination IDs.
TEAMS_POST_METHOD=webhook
# Options: webhook, graph_chat, graph_channel
TEAMS_GRAPH_TENANT_ID=
TEAMS_GRAPH_CLIENT_ID=
TEAMS_GRAPH_CLIENT_SECRET=
TEAMS_GRAPH_TOKEN_CACHE_PATH=.graph_teams_token_cache.bin
TEAMS_CHAT_ID=
TEAMS_TEAM_ID=
TEAMS_CHANNEL_ID=

# Optional email snapshot storage.
SAVE_EMAIL_HTML=false
EMAIL_SNAPSHOT_DIR=email_snapshots

# Weekly Remit Agent settings.
# V1 sends ICR weekly remit and liquidation Excel reports to the broker.
REMIT_BROKER_NAME=ICR
REMIT_BROKER_EMAIL=jprawel@icroffice.com
REMIT_INCOMING_FOLDER=remits/incoming/ICR
REMIT_SENT_FOLDER=remits/sent/ICR
REMIT_FAILED_FOLDER=remits/failed/ICR
REMIT_DUPLICATE_FOLDER=remits/duplicates/ICR
REMIT_REMIT_FILENAME_CONTAINS=United Remit
REMIT_LIQUIDATION_FILENAME_CONTAINS=United Liq
REMIT_ALLOWED_EXTENSIONS=.xlsx,.xls,.csv
REMIT_SEND_MODE=send
REMIT_RUN_DAY=monday
REMIT_SEND_DEADLINE=15:00
REMIT_SCAN_INTERVAL_MINUTES=15
REMIT_SEND_OWNER_TEAMS_UPDATE=true
REMIT_OWNER_TEAMS_CHAT_ID=

# Voicemail Tracker Agent Phase 1 settings.
# Uses the same MS_GRAPH_* app registration for Outlook mailbox read access.
VOICEMAIL_MAILBOX_USER_ID=voicemail@example.com
VOICEMAIL_SENDER_EMAIL=voicemail@vaspian.com
VOICEMAIL_SUBJECT_CONTAINS=voicemail
VOICEMAIL_LOOKBACK_HOURS=48

# Operations Intelligence Agent settings.
# V1 watches the Teams leadership chat for the daily SCollect screenshot.
OPS_LEADERSHIP_CHAT_ID=
OPS_LOOKBACK_HOURS=30
OPS_DAILY_SCAN_START=17:00
OPS_DAILY_SCAN_END=18:15
OPS_SCAN_INTERVAL_MINUTES=10
OPS_SCREENSHOTS_DIR=screenshots/operations-intelligence
OPS_REPORTS_DIR=reports/operations-intelligence
OPS_OCR_COMMAND=tesseract
OPS_OCR_MIN_CONFIDENCE=0.72
OPS_OCR_DEBUG=false
OPS_POST_SUMMARY_TO_TEAMS=true
OPS_LOW_QUALITY_ACTION=alert
OPS_COLLECTOR_CODES=CSOLO,VMAR,KMAD,UNITED HOUSE

# Cash Flow HQ Notion setup.
# NOTION_API_KEY comes from the Notion Developer portal integration/PAT token.
# Share the parent Notion page with that integration before running setup or scans.
NOTION_API_KEY=
# CASH_FLOW_HQ_PARENT_PAGE_ID comes from the Notion page URL where Cash Flow HQ should live.
CASH_FLOW_HQ_PARENT_PAGE_ID=
# Usually leave this as Cash Flow HQ unless you intentionally renamed the database.
CASH_FLOW_HQ_DATABASE_NAME=Cash Flow HQ
# Optional: pin exact Notion data sources to avoid duplicate database title lookup.
CASH_FLOW_HQ_DATA_SOURCE_ID=
VENDOR_RULES_DATA_SOURCE_ID=
# Direct Teams alerts for Cash Flow HQ. Sends to this user only.
CASH_FLOW_HQ_TEAMS_USER=jaye@unitedaccountservices.com
# Optional: use an existing private chat if delegated Graph sender is the same user.
CASH_FLOW_HQ_TEAMS_CHAT_ID=
CASH_FLOW_HQ_NOTIFICATION_TIME=08:00
# Must match the Notion API version used by the Cash Flow HQ code.
NOTION_VERSION=2026-03-11

# Cash Flow HQ Outlook email scan.
# Uses the same MS_GRAPH_* app registration as the other Outlook agents.
# Required Graph application permission: Mail.Read
CASH_FLOW_HQ_MAILBOX_USER_ID=
